# .sass-cache/
# .jekyll-metadata

# Tencent Cloud EdgeOne
.env
.edgeone/*
.tef_dist/*
# 历史：edgeone 曾输出 site/；现已改为根目录 outputDirectory: .
site/

# OpenClaw 配置文件（与任务无关）
openclaw.json
openclaw.json.bak*

# scripts 目录下的 OpenClaw 控制脚本（与任务无关）
/scripts/
