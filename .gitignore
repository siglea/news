.claude/
.cursor/
.continue/
.aider*

# Playwright 抓取产物（勿提交）
util/.crawl-output/

# 日志和临时文件
*.log
*.tmp
*.temp
temp/
tmp/

# 操作系统文件
Thumbs.db
desktop.ini

# 本地配置（如需保留某些本地配置，可以注释下面几行）
# .env
# config.local.js

# EdgeOne Pages（勿提交 Token）
.edgeone/.token

# Gitee Pages 不需要忽略的文件
