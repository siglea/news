  "comment": "哲学稿 gen_dense 补充；长 zh 优先匹配，减少与全局表误配",
  "entries": [
    {"zh": "那些真正献身哲学的人，实际上就是在练习死亡。", "en": "philosophy-as-death-rehearsal", "ipa": "[fɪˈlɒsəfi æz deθ rɪˈhɜːsl]", "pos": "n.", "gloss": "哲学即练习面对死亡"},
    {"zh": "未经省察的人生不值得过。", "en": "unexamined-life-motto", "ipa": "[ˌʌnɪɡˈzæmɪnd laɪf ˈmɒtəʊ]", "pos": "n.", "gloss": "未经省察的人生不值得过"},
    {"zh": "人是向死而生的存在者，死亡是此在最本己、无所旁涉、不可逾越的可能性。", "en": "being-toward-death-maxim", "ipa": "[ˈbiːɪŋ təˈwɔːd deθ ˈmæksɪm]", "pos": "n.", "gloss": "向死而在（海德格尔命题）"},
    {"zh": "真正严肃的哲学问题只有一个：自杀。", "en": "suicide-as-sole-problem", "ipa": "[ˈsuːɪsaɪd æz səʊl ˈprɒbləm]", "pos": "n.", "gloss": "自杀作为唯一严肃哲学问题"},
    {"zh": "死亡不是生命中的事件，我们不能体验它；永恒的生命，在于活在当下的每一刻。", "en": "death-not-an-experience", "ipa": "[deθ nɒt ən ɪkˈspɪəriəns]", "pos": "n.", "gloss": "死亡不可被体验（维特根斯坦）"},
    {"zh": "不要畏惧死亡，它是自然秩序的一部分。", "en": "death-as-natural-order", "ipa": "[deθ æz ˈnæʧərəl ˈɔːdə]", "pos": "n.", "gloss": "死亡是自然秩序"},
    {"zh": "死亡是真正激励哲学、给哲学以灵感的守护神", "en": "death-as-muse", "ipa": "[deθ æz mjuːz]", "pos": "n.", "gloss": "死亡激发哲学"},
    {"zh": "对待生命不妨大胆一点，因为终要失去它。", "en": "carpe-diem-boldness", "ipa": "[ˈkɑːpeɪ ˈdiːem ˈbəʊldnəs]", "pos": "n.", "gloss": "因终将失去而大胆活"},
    {"zh": "如果一个人的生活将无限次重复，他是否有勇气说“再一次”？", "en": "eternal-recurrence-test", "ipa": "[ɪˈtɜːnl rɪˈkɜːrəns test]", "pos": "n.", "gloss": "永恒轮回思想实验"},
    {"zh": "先行到死中去", "en": "anticipate-death", "ipa": "[ænˈtɪsɪpeɪt deθ]", "pos": "v.", "gloss": "先行到死中去"},
